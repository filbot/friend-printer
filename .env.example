# Copy this file to .env and fill in real values.
# .env is gitignored — never commit your token.

# From @BotFather after creating your bot.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Comma-separated numeric Telegram user IDs allowed to print (not @usernames).
# Easiest way to look up someone's ID: have them message @userinfobot.
# Whitespace around commas is fine.
ALLOWED_USER_IDS=123456789,987654321
