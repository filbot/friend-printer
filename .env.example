# Copy this file to .env and fill in real values.
# .env is gitignored — never commit your token.

# From @BotFather after creating your bot.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Your friend's numeric Telegram user ID (not their @username).
# Easiest way to look it up: have them message @userinfobot.
ALLOWED_USER_ID=123456789
